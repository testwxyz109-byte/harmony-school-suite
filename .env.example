# Copy to .env and edit before running `docker compose up`

# --- MySQL (used by the mysql container) ---
MYSQL_ROOT_PASSWORD=rootsecret
MYSQL_DATABASE=school
MYSQL_USER=school
MYSQL_PASSWORD=schoolsecret

# --- App (read by the Node server inside the app container) ---
# When the app runs in docker-compose, host = "mysql" (the service name).
# When running the app on your host machine against dockerized MySQL, use 127.0.0.1.
DATABASE_URL=mysql://school:schoolsecret@mysql:3306/school

# 32+ random chars. Generate with: openssl rand -hex 32
JWT_SECRET=replace-with-a-long-random-string

# Where uploaded files (student photos, school logo, etc.) are stored inside the container.
# Mounted as a docker volume in docker-compose.yml.
UPLOAD_DIR=/app/uploads

# Used to build absolute URLs for emails / public result links.
PUBLIC_BASE_URL=http://localhost:3000
