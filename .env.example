# --- App secrets ---
# Generate with: openssl rand -hex 32
JWT_SECRET=replace-with-a-long-random-string-min-32-chars

# Origin(s) allowed to call the API. For production, set to your real domain.
# Comma-separated list. Use "*" to allow any (NOT recommended for prod).
ALLOWED_ORIGINS=http://localhost:3000

# Host port the web container is exposed on
WEB_PORT=3000
